# ═══════════════════════════════════════════════════════════════════════
# .env.example — committed to git as a reference for required env vars.
#
# Copy this to:
#   .env.local              (always loaded by Next.js for local development)
#
# The target file is gitignored. Never commit real values.
# ═══════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.example

# ── InsForge ───────────────────────────────────────────────────────────
# Public base URL of the InsForge backend (browser-exposed).
NEXT_PUBLIC_INSFORGE_BASE_URL=https://<app>.<region>.insforge.app
# Public anon key for client-side InsForge SDK (browser-exposed).
NEXT_PUBLIC_INSFORGE_ANON_KEY=
# Server-only admin API key. NEVER expose to the browser.
INSFORGE_API_KEY=
# Server-only direct Postgres URL. Used by db introspection / bootstrap scripts.
INSFORGE_DB_URL=postgresql://postgres:<password>@<app>.<region>.database.insforge.app:5432/insforge?sslmode=require

# ── AI Models ──────────────────────────────────────────────────────────
# Pioneer AI (OpenAI-compatible endpoint, default: DeepSeek V4 Flash)
PIONEER_API_KEY=
PIONEER_MODEL=deepseek-ai/DeepSeek-V4-Flash
# Optional: override Pioneer base URL (default: https://api.pioneer.ai/v1)
# PIONEER_BASE_URL=
# Legacy Google Cloud credentials removed per security audit

VOYAGE_API_KEY=
EMBEDDING_RATE_LIMIT_RPM=60

# ── GitHub App & OAuth ──────────────────────────────────────────────────
# Paste the Client ID from your GitHub App settings:
GITHUB_CLIENT_ID=
# Paste the Client Secret generated in your GitHub App settings:
GITHUB_CLIENT_SECRET=
# Webhook Secret matching the one configured in the GitHub App webhook settings:
GITHUB_WEBHOOK_SECRET=
# Fallback Personal Access Token (PAT) for API requests:
GITHUB_TOKEN=
# Paste the App ID from your GitHub App General page:
GITHUB_APP_ID=
# Paste the raw PEM private key body as a single line with \n for newlines:
GITHUB_APP_PRIVATE_KEY=
# The public installation URL of your GitHub App (e.g. https://github.com/apps/your-app-name-here):
NEXT_PUBLIC_GITHUB_APP_URL=

# ── Google OAuth (consumer) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Upstash QStash (cron + workflows) ──────────────────────────────────
QSTASH_URL=https://qstash-us-east-1.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Public origin QStash can reach to call workflow handlers.
UPSTASH_WORKFLOW_URL=https://your-domain.example

# ── Daytona (sandbox) ──────────────────────────────────────────────────
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=eu

# ── Email ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── External APIs ──────────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ── Cron / Security ────────────────────────────────────────────────────
CRON_SECRET=
# AES-256-GCM master key for OAuth/Telegram token encryption. 32 random bytes, base64.
TOKEN_ENC_KEY=
# Optional multi-key rotation. JSON map of keyId -> base64 32-byte key, plus the
# active key id. Legacy TOKEN_ENC_KEY is still supported when these are unset.
TOKEN_ENC_KEYS=
TOKEN_ENC_ACTIVE_KEY_ID=
# Set to `true` to enforce the Content-Security-Policy. Unset = report-only.
CSP_ENFORCE=
# Required by scripts/db-introspect-prod.ts and db-seed-from-prod.ts guard.
PROD_PROJECT_REF=
# Comma-separated allowlist for cron/memory-sync per-user invocation.
INTERNAL_CRON_USER_IDS=
# Operator PAT for the public portfolio chatbot. Falls back to GITHUB_TOKEN.
PORTFOLIO_CHAT_GITHUB_PAT=
